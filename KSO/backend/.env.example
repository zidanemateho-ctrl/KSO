NODE_ENV=development
PORT=4000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/kso?schema=public"

JWT_SECRET="CHANGE_THIS_SECRET_TO_A_LONG_RANDOM_STRING"
JWT_REFRESH_SECRET="CHANGE_THIS_REFRESH_SECRET_TO_A_LONG_RANDOM_STRING"
JWT_EXPIRES_IN="15m"
ACCESS_TOKEN_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN="30d"

# URL(s) front autorisees (separer par virgule)
FRONTEND_URL="http://kso.digital-get.com"
PUBLIC_BASE_URL="http://localhost:4000"

# Cookies auth
AUTH_COOKIE_DOMAIN=""
AUTH_COOKIE_SAME_SITE="lax"
AUTH_COOKIE_SECURE="false"

# Rate limiting
RATE_LIMIT_GLOBAL_MAX=1500
RATE_LIMIT_GLOBAL_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=20
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_UPLOAD_MAX=30
RATE_LIMIT_UPLOAD_WINDOW_MS=900000

# Stockage fichiers
FILE_STORAGE_DRIVER="local"
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_FOLDER="kso/chat"

# Observabilite
LOG_LEVEL="info"
METRICS_TOKEN=""
OBSERVABILITY_WEBHOOK_URL=""

# Reset password
PASSWORD_RESET_TOKEN_EXPIRES_MINUTES=30
PASSWORD_RESET_BASE_URL="http://localhost:5173/reset-password"
RESEND_API_KEY=""
MAIL_FROM=""
